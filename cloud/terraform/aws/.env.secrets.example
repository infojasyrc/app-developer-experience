# =============================================================================
# .env.secrets.example — Secrets Manager bootstrap template
#
# Copy this file to .env.secrets and fill in strong, unique passwords.
#
#   cp .env.secrets.example .env.secrets
#
# .env.secrets is gitignored — NEVER commit it.
# It is read by: make secrets-bootstrap
#
# Who fills this in:
#   The AWS account owner / admin running the one-time bootstrap.
#   Regular developers and CI/CD pipelines do NOT need this file.
#
# Password requirements:
#   - Minimum 16 characters
#   - Mix of uppercase, lowercase, digits, and symbols
#   - Use a password manager (e.g., 1Password, Bitwarden) to generate
# =============================================================================

# ── MongoDB (ms-conference-api sidecar) ──────────────────────────────────────
# Stored at: /appdevexp/dev/mongo/admin
# Keys injected into ECS: MONGO_INITDB_ROOT_USERNAME, MONGO_INITDB_ROOT_PASSWORD
MONGO_ADMIN_USERNAME=mongoadmin
MONGO_ADMIN_PASSWORD=

# ── Keycloak (tools service) ──────────────────────────────────────────────────
# Stored at: /appdevexp/dev/keycloak/admin
# Keys injected into ECS: KC_BOOTSTRAP_ADMIN_USERNAME, KC_BOOTSTRAP_ADMIN_PASSWORD
# Used on first Keycloak container startup only; safe to rotate afterward.
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=

# ── PostgreSQL (tools service sidecar) ───────────────────────────────────────
# Stored at: /appdevexp/dev/postgres/tools
# Key injected into ECS: POSTGRES_PASSWORD (postgres), DATABASE_PASSWORD (unleash),
#                        GF_DATABASE_PASSWORD (grafana), KC_DB_PASSWORD (keycloak)
# All four tools share this single PostgreSQL instance via separate databases.
POSTGRES_TOOLS_PASSWORD=

# ── Grafana (tools service) ───────────────────────────────────────────────────
# Stored at: /appdevexp/dev/grafana/admin
# Key injected into ECS: GF_SECURITY_ADMIN_PASSWORD
# This is the local admin fallback; Keycloak SSO is the primary login method.
GRAFANA_ADMIN_PASSWORD=

# ── Unleash (tools service) ───────────────────────────────────────────────────
# Stored at: /appdevexp/dev/unleash/admin
# Key injected into ECS: UNLEASH_DEFAULT_ADMIN_PASSWORD
UNLEASH_ADMIN_PASSWORD=

# ── Grafana Keycloak OAuth client secret ─────────────────────────────────────
# Stored at: /appdevexp/dev/keycloak/grafana-client-secret
# Key injected into ECS: GF_AUTH_GENERIC_OAUTH_CLIENT_SECRET
#
# IMPORTANT: Leave empty on first bootstrap. This value is generated inside the
# Keycloak admin console after the tools service starts for the first time.
# Steps:
#   1. Run: make secrets-bootstrap (creates a placeholder value)
#   2. Start the tools ECS service (Phase 4 of the infra plan)
#   3. Log into Keycloak at keycloak.<domain> with the admin credentials above
#   4. Navigate to: conference-manager-tools realm → Clients → grafana → Credentials
#   5. Copy the client secret
#   6. Run: make secrets-rotate \
#              SECRET_NAME=/appdevexp/dev/keycloak/grafana-client-secret \
#              NEW_VALUE='{"secret":"<paste-secret-here>"}'
KEYCLOAK_GRAFANA_CLIENT_SECRET=
