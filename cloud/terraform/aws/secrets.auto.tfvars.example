# =============================================================================
# secrets.auto.tfvars.example — Sensitive Terraform variable template
#
# Copy this file to secrets.auto.tfvars and fill in real values for local runs.
#
#   cp secrets.auto.tfvars.example secrets.auto.tfvars
#
# secrets.auto.tfvars is gitignored.
# Terraform loads *.auto.tfvars automatically — no -var-file flag needed.
#
# In CI/CD (GitHub Actions), these values are NOT read from this file.
# They are passed as TF_VAR_* environment variables sourced from GitHub secrets:
#   TF_VAR_db_username  ← secrets.DB_USERNAME
#   TF_VAR_db_password  ← secrets.DB_PASSWORD
#
# Local development only — never commit this file.
# =============================================================================

db_username = ""
db_password = ""
