{
  "name": "@conference-manager/ms-conference-api",
  "version": "1.0.0",
  "description": "Conference Manager API",
  "scripts": {
    "build": "nest build",
    "lint": "npx eslint .",
    "prepare": "husky",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "test:ci": "yarn test --coverage",
    "test:coverage": "yarn test --coverage",
    "test:unit-tests": "yarn run test:unit-tests:v1 && yarn run test:unit-tests:v2",
    "test:unit-tests:v1": "c8 --reporter=lcov ava",
    "test:unit-tests:v2": "jest --runInBand --coverage --detectOpenHandles",
    "test:watch:v1": "ava --watch",
    "test:watch:v2": "jest --watchAll",
    "dedupe": "yarn-deduplicate yarn.lock",
    "security:audit": "audit-ci --high --critical --report-type summary --config audit-ci.json",
    "security:fix": "yarn upgrade && yarn install || true"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "engines": {
    "node": "20"
  },
  "private": true,
  "devDependencies": {
    "@ava/babel": "^2.0.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-angular": "^19.8.1",
    "@nestjs/testing": "^11.1.21",
    "@types/jest": "^29.5.11",
    "@types/semver": "^7.7.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.8",
    "audit-ci": "^7.1.0",
    "ava": "^5.2.0",
    "c8": "^10.1.3",
    "env-cmd": "^10.1.0",
    "eslint": "^8.39.0",
    "eslint-plugin-promise": "^6.1.1",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-mock-extended": "^3.0.5",
    "mock-req-res": "^1.2.0",
    "nodemon": "^3.1.9",
    "proxyquire": "^2.1.3",
    "sinon": "^15.0.4",
    "supertest": "^7.1.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "ts-jest": "^29.1.2",
    "yamljs": "^0.3.0",
    "yarn-deduplicate": "^6.0.2"
  },
  "dependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/common": "^11.1.21",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.21",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.0.6",
    "@nestjs/mongoose": "^11.0.3",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.21",
    "@nestjs/swagger": "^11.0.7",
    "@nestjs/testing": "^11.1.21",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/passport-strategy": "^0.2.38",
    "body-parser": "^1.19.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^5.0.0",
    "firebase-admin": "^13.10.0",
    "joi": "^17.9.2",
    "js-yaml": "^4.1.0",
    "json2csv": "^5.0.1",
    "mongodb": "^5.6.0",
    "mongodb-memory-server": "^9.1.6",
    "mongoose": "^8.22.1",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-custom": "^1.1.1",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.2",
    "typescript": "^5.3.3",
    "unleash-client": "^5.3.0",
    "uuid": "^9.0.0",
    "xhr2": "^0.2.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "yarn run lint && yarn run test:unit-tests:v1 && test:unit-tests:v2"
    }
  },
  "nodemonConfig": {
    "ignore": [
      "tests/*"
    ],
    "verbose": false
  },
  "resolutions": {
    "protobufjs": ">=7.5.6",
    "semver": ">=7.5.2",
    "validator": ">=13.15.22",
    "serialize-javascript": ">=6.0.2",
    "flatted": ">=3.4.0",
    "node-forge": ">=1.3.1",
    "tar": ">=7.0.3",
    "picomatch": ">=2.3.2",
    "fast-uri": ">=3.1.2",
    "form-data": ">=4.0.4",
    "jws": ">=4.0.1",
    "lodash": ">=4.18.0"
  }
}
